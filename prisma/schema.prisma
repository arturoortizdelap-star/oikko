generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Producto {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  color       String?
  tallas      String
  piezas      Int      @default(0)
  precio      Float
  costo       Float    @default(0)
  imagen      String?
  categoria   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  pedidoItems PedidoItem[]
}

model Pedido {
  id             Int          @id @default(autoincrement())
  origen         String
  proveedor      String?
  estatus        String       @default("en_camino")
  notas          String?
  linkRastreo    String?
  fechaEstimada  DateTime?
  fecha          DateTime     @default(now())
  items          PedidoItem[]
}

model Compostura {
  id            Int      @id @default(autoincrement())
  cliente       String
  prenda        String
  descripcion   String
  entrega       DateTime?
  estatus       String   @default("pendiente") // pendiente | entregada
  fecha         DateTime @default(now())
}

model PedidoItem {
  id         Int      @id @default(autoincrement())
  pedido     Pedido   @relation(fields: [pedidoId], references: [id])
  pedidoId   Int
  producto   Producto @relation(fields: [productoId], references: [id])
  productoId Int
  cantidad   Int
  talla      String?
}

model Movimiento {
  id         Int      @id @default(autoincrement())
  tipo       String   // ingreso | gasto
  categoria  String   @default("otros") // ventas | compras_oficina | nomina | otros
  concepto   String
  monto      Float
  fecha      DateTime @default(now())
}

model Configuracion {
  id    Int    @id @default(autoincrement())
  clave String @unique
  valor String
}

model Usuario {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  nombre   String?
}

model Venta {
  id          Int        @id @default(autoincrement())
  cliente     String
  telefono    String?
  total       Float
  fecha       DateTime   @default(now())
  items       VentaItem[]
}

model VentaItem {
  id         Int     @id @default(autoincrement())
  venta      Venta   @relation(fields: [ventaId], references: [id])
  ventaId    Int
  productoId Int
  nombre     String
  precio     Float
  cantidad   Int     @default(1)
  talla      String?
  imagen     String?
}
